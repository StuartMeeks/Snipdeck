<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Snipdeck.App.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Snipdeck.App.Controls"
    xmlns:converters="using:Snipdeck.App.Converters"
    xmlns:local="using:Snipdeck.App.Views"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:Snipdeck.Core.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ShellRoot">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibility" Invert="True" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibility" />

        <DataTemplate x:Key="HomeContentTemplate" x:DataType="vm:HomeViewModel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24" Spacing="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="CLIs"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="New CLI"
                                Click="OnNewCliClicked"
                                Style="{ThemeResource AccentButtonStyle}" />
                    </Grid>

                    <GridView ItemsSource="{x:Bind CliCards}"
                              SelectionMode="None"
                              IsItemClickEnabled="False"
                              Visibility="{x:Bind HasCliCards, Converter={StaticResource BoolToVisibility}}">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:CliCardViewModel">
                                <controls:CliCard
                                    ViewModel="{x:Bind}"
                                    NavigateCommand="{Binding ElementName=ShellRoot, Path=ViewModel.SelectCliCommand}"
                                    Margin="0,0,12,12" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>

                    <StackPanel Spacing="12"
                                Visibility="{x:Bind MostUsedSnips.Count, Converter={StaticResource CountToVisibility}, Mode=OneWay}">
                        <TextBlock Text="Most used"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <ItemsControl ItemsSource="{x:Bind MostUsedSnips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SnipCardViewModel">
                                    <controls:SnipCard
                                        ViewModel="{x:Bind}"
                                        CopyCommand="{Binding ElementName=ShellRoot, Path=ViewModel.CopySnipCommand}"
                                        EditCommand="{Binding ElementName=ShellRoot, Path=ViewModel.EditSnipCommand}"
                                        DeleteCommand="{Binding ElementName=ShellRoot, Path=ViewModel.DeleteSnipCommand}"
                                        FavouriteCommand="{Binding ElementName=ShellRoot, Path=ViewModel.ToggleFavouriteCommand}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Spacing="8"
                                HorizontalAlignment="Center"
                                Visibility="{x:Bind HasCliCards, Converter={StaticResource InvertedBoolToVisibility}}">
                        <TextBlock Text="Welcome to Snipdeck"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Start by adding a CLI."
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate x:Key="CliContentTemplate" x:DataType="vm:CliViewModel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24" Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Margin="0,0,8,0"
                                Content="Edit CLI"
                                Click="OnEditCliClicked" />
                        <Button Grid.Column="2"
                                Content="New snip"
                                Click="OnNewSnipClicked"
                                Style="{ThemeResource AccentButtonStyle}" />
                    </Grid>

                    <TextBlock Text="No snips match the current filter."
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{x:Bind IsEmpty, Converter={StaticResource BoolToVisibility}}" />

                    <ItemsControl ItemsSource="{x:Bind Snips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SnipCardViewModel">
                                <controls:SnipCard
                                    ViewModel="{x:Bind}"
                                    CopyCommand="{Binding ElementName=ShellRoot, Path=ViewModel.CopySnipCommand}"
                                    EditCommand="{Binding ElementName=ShellRoot, Path=ViewModel.EditSnipCommand}"
                                    DeleteCommand="{Binding ElementName=ShellRoot, Path=ViewModel.DeleteSnipCommand}"
                                    FavouriteCommand="{Binding ElementName=ShellRoot, Path=ViewModel.ToggleFavouriteCommand}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate" x:DataType="vm:SettingsViewModel">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="24" Spacing="8" MaxWidth="720" HorizontalAlignment="Stretch">
                    <TextBlock Text="Settings"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Margin="0,0,0,8" />

                    <tk:SettingsCard Header="Storage location"
                                     Description="Where snipdeck keeps your snips. Configurable in Phase 6."
                                     IsEnabled="False" />

                    <tk:SettingsCard Header="Backups"
                                     Description="Backup directory and retention. Configurable in Phase 6."
                                     IsEnabled="False" />

                    <tk:SettingsCard Header="Theme"
                                     Description="Light, Dark, or System. Live switching in Phase 6."
                                     IsEnabled="False" />

                    <tk:SettingsCard Header="Global hotkey"
                                     Description="Default Ctrl+Alt+S. Rebinding in Phase 6."
                                     IsEnabled="False" />

                    <tk:SettingsCard Header="Close behaviour"
                                     Description="Hide-to-tray vs exit. Configurable in Phase 6."
                                     IsEnabled="False" />

                    <tk:SettingsExpander Header="About">
                        <tk:SettingsExpander.Items>
                            <tk:SettingsCard Header="Application">
                                <StackPanel HorizontalAlignment="Right">
                                    <TextBlock Text="{x:Bind AppName}" />
                                    <TextBlock Text="{x:Bind TaglineDisplay}"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </tk:SettingsCard>
                            <tk:SettingsCard Header="Version">
                                <TextBlock Text="{x:Bind VersionDisplay}" />
                            </tk:SettingsCard>
                            <tk:SettingsCard Header="Copyright">
                                <TextBlock Text="{x:Bind CopyrightDisplay}" />
                            </tk:SettingsCard>
                        </tk:SettingsExpander.Items>
                    </tk:SettingsExpander>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <local:ShellContentTemplateSelector x:Key="ShellContentSelector"
                                             HomeTemplate="{StaticResource HomeContentTemplate}"
                                             CliTemplate="{StaticResource CliContentTemplate}"
                                             SettingsTemplate="{StaticResource SettingsContentTemplate}" />
    </UserControl.Resources>

    <NavigationView x:Name="ShellNavigation"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Left"
                    OpenPaneLength="280"
                    MenuItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedTag, Mode=TwoWay}"
                    SelectionChanged="OnNavigationSelectionChanged">

        <NavigationView.PaneHeader>
            <StackPanel Padding="12,8" Spacing="8">
                <AutoSuggestBox PlaceholderText="Search"
                                QueryIcon="Find"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

                <ComboBox ItemsSource="{x:Bind ViewModel.CliChoices, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedCliChoice, Mode=TwoWay}"
                          DisplayMemberPath="Display"
                          HorizontalAlignment="Stretch" />
            </StackPanel>
        </NavigationView.PaneHeader>

        <NavigationView.PaneFooter>
            <Button x:Name="SettingsButton"
                    Click="OnSettingsClicked"
                    HorizontalAlignment="Stretch"
                    Margin="12,8"
                    Background="Transparent"
                    BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </NavigationView.PaneFooter>

        <ContentControl Content="{x:Bind ViewModel.CurrentContent, Mode=OneWay}"
                        ContentTemplateSelector="{StaticResource ShellContentSelector}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
    </NavigationView>
</UserControl>
